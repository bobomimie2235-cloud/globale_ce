{% extends 'admin/layout/base_admin.html.twig' %}
{% block title %}Nouvelle catégorie coupon{% endblock %}

{% block body %}

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
      <span class="text-muted fw-light">Admin / <a href="{{ path('admin_coupon_index') }}">Coupons</a> /
      <a href="{{ path('admin_coupon_categorie_index') }}">Catégories</a> /</span>
      Nouvelle catégorie
    </h4>
    <a href="{{ path('admin_coupon_categorie_index') }}" class="btn btn-outline-secondary">
      <i class="bx bx-arrow-back me-1"></i> Retour
    </a>
  </div>

  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0"><i class="bx bx-tag me-2 text-primary"></i>Nouvelle catégorie coupon</h5>
        </div>
        <div class="card-body">
          {{ form_start(form) }}
            <div class="mb-3">
              <label class="form-label">{{ form_label(form.categorie) }}</label>
              {{ form_widget(form.categorie, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Restaurant, Bijoux...'}}) }}
              {{ form_errors(form.categorie) }}
            </div>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">
                <i class="bx bx-plus me-1"></i> Créer
              </button>
              <a href="{{ path('admin_coupon_categorie_index') }}" class="btn btn-outline-secondary">
                Annuler
              </a>
            </div>
          {{ form_end(form) }}
        </div>
      </div>
    </div>
  </div>

{% endblock %}
