{% extends 'admin/layout/base_admin.html.twig' %}
{% block title %}Modifier {{ utilisateur.prenom }} {{ utilisateur.nom }}{% endblock %}

{% block body %}

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
      <span class="text-muted fw-light">Admin / <a href="{{ path('admin_utilisateur_index') }}">Utilisateurs</a> /</span>
      Modifier
    </h4>
    <div class="d-flex gap-2">
      <a href="{{ path('admin_utilisateur_show', {id: utilisateur.id}) }}" class="btn btn-outline-primary">
        <i class="bx bx-show me-1"></i> Voir
      </a>
      <a href="{{ path('admin_utilisateur_index') }}" class="btn btn-outline-secondary">
        <i class="bx bx-arrow-back me-1"></i> Retour
      </a>
    </div>
  </div>

  <div class="row">

    {# ===== Infos personnelles ===== #}
    <div class="col-md-7 mb-4">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0">
            <i class="bx bx-user me-2 text-primary"></i>
            Informations personnelles
          </h5>
        </div>
        <div class="card-body">
          {{ form_start(form) }}
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">{{ form_label(form.nom) }}</label>
                {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.nom) }}
              </div>
              <div class="col-md-6">
                <label class="form-label">{{ form_label(form.prenom) }}</label>
                {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.prenom) }}
              </div>
              <div class="col-12">
                <label class="form-label">{{ form_label(form.email) }}</label>
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.email) }}
              </div>
              <div class="col-12 mt-3">
  <label class="form-label fw-semibold">Groupe</label>
  {{ form_widget(form.utilisateurGroupe, {'attr': {'class': 'form-select'}}) }}
  {{ form_errors(form.utilisateurGroupe) }}
</div>

<div class="col-12 mt-3">
  <label class="form-label fw-semibold">Rôles</label>
  <div class="d-flex flex-wrap gap-3 mt-1">
    {% for role in form.roles %}
      <div class="form-check">
        {{ form_widget(role, {'attr': {'class': 'form-check-input'}}) }}
        {{ form_label(role, null, {'label_attr': {'class': 'form-check-label'}}) }}
      </div>
    {% endfor %}
  </div>
  {{ form_errors(form.roles) }}
</div>
            </div>
            <div class="mt-4">
              <button type="submit" class="btn btn-primary">
                <i class="bx bx-save me-1"></i> Enregistrer les modifications
              </button>
            </div>
          {{ form_end(form) }}
        </div>
      </div>
    </div>

    {# ===== Infos du compte ===== #}
    <div class="col-md-5 mb-4">
      <div class="card mb-4">
        <div class="card-header">
          <h5 class="mb-0">
            <i class="bx bx-info-circle me-2 text-info"></i>
            Informations du compte
          </h5>
        </div>
        <div class="card-body">
          <p class="mb-2">
            <span class="text-muted">ID :</span>
            <strong>#{{ utilisateur.id }}</strong>
          </p>
          <p class="mb-2">
            <span class="text-muted">Inscrit le :</span>
            <strong>{{ utilisateur.dateInscription|date('d/m/Y') }}</strong>
          </p>
          <p class="mb-2">
            <span class="text-muted">Groupe :</span>
            {% if utilisateur.utilisateurGroupe %}
              <span class="badge bg-label-secondary">{{ utilisateur.utilisateurGroupe.nomGroupe }}</span>
            {% else %}
              <span class="text-muted">—</span>
            {% endif %}
          </p>
          <p class="mb-0">
            <span class="text-muted">Rôles :</span>
            {% for role in utilisateur.roles %}
              <span class="badge bg-label-{{ role == 'ROLE_ADMIN' ? 'danger' : 'success' }} ms-1">
                {{ role }}
              </span>
            {% endfor %}
          </p>
        </div>
      </div>

      {# ===== Suppression ===== #}
      {% if utilisateur != app.user %}
        <div class="card border-danger">
          <div class="card-header bg-label-danger">
            <h5 class="mb-0 text-danger">
              <i class="bx bx-trash me-2"></i> Zone dangereuse
            </h5>
          </div>
          <div class="card-body">
            <p class="text-muted small mb-3">
              La suppression est irréversible. Toutes les données de cet utilisateur seront perdues.
            </p>
            <form method="POST"
                  action="{{ path('admin_utilisateur_delete', {id: utilisateur.id}) }}"
                  onsubmit="return confirm('Supprimer définitivement cet utilisateur ?')">
              <input type="hidden" name="_token"
                     value="{{ csrf_token('delete' ~ utilisateur.id) }}">
              <button type="submit" class="btn btn-danger w-100">
                <i class="bx bx-trash me-1"></i> Supprimer cet utilisateur
              </button>
            </form>
          </div>
        </div>
      {% endif %}

    </div>
  </div>

{% endblock %}
