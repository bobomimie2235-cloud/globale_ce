{% extends 'admin/layout/base_admin.html.twig' %}
{% block title %}Articles{% endblock %}

{% block body %}

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
      <span class="text-muted fw-light">Admin /</span> Offres Commerçants
    </h4>
    <a href="{{ path('admin_article_new') }}" class="btn btn-primary">
      <i class="bx bx-plus me-1"></i> Nouvelle Offre
    </a>
  </div>

  {# ===== FILTRES ===== #}
  <div class="card mb-4">
    <div class="card-body">
      <form method="GET" class="row g-3 align-items-end">
        <div class="col-md-4">
          <label class="form-label">Recherche</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bx bx-search"></i></span>
            <input type="text" name="search" class="form-control"
                   placeholder="Titre, description, offre..." value="{{ search ?? '' }}">
          </div>
        </div>
        <div class="col-md-3">
          <label class="form-label">Catégorie</label>
          <select name="categorie" class="form-select">
            <option value="">Toutes les catégories</option>
            {% for categorie in categories %}
              <option value="{{ categorie.id }}"
                {{ categorieActif == categorie.id ? 'selected' : '' }}>
                {{ categorie.intitule }}
              </option>
            {% endfor %}
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Département</label>
          <select name="departement" class="form-select">
            <option value="">Tous les départements</option>
            {% for dept in departements %}
              <option value="{{ dept.id }}"
                {{ deptActif == dept.id ? 'selected' : '' }}>
                {{ dept }}
              </option>
            {% endfor %}
          </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
          <button type="submit" class="btn btn-primary w-100">
            <i class="bx bx-filter-alt"></i> Filtrer
          </button>
          <a href="{{ path('admin_article_index') }}" class="btn btn-outline-secondary">
            <i class="bx bx-x"></i>
          </a>
        </div>
      </form>
    </div>
  </div>

  {# ===== TABLEAU ===== #}
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Liste des articles</h5>
      <span class="badge bg-label-primary">{{ articles|length }} article(s)</span>
    </div>
    <div class="card-body p-0">
      {% if articles is not empty %}
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Logo</th>
                <th>Titre</th>
                <th>Catégorie</th>
                <th>Offre</th>
                <th>Département</th>
                <th>Auteur</th>
                <th class="text-center">Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for article in articles %}
                <tr>
                  <td>
                    {% if article.imgLogo %}
                      <img src="{{ asset('uploads/articles/' ~ article.imgLogo) }}"
                           alt="{{ article.titre }}"
                           class="rounded" style="width:40px;height:40px;object-fit:cover;">
                    {% else %}
                      <span class="avatar avatar-sm">
                        <span class="avatar-initial rounded bg-label-info">
                          <i class="bx bx-store"></i>
                        </span>
                      </span>
                    {% endif %}
                  </td>
                  <td>
                    <strong>{{ article.titre }}</strong>
                    {% if article.siteWeb %}
                      <br><a href="{{ article.siteWeb }}" target="_blank" class="text-muted small">
                        <i class="bx bx-link-external me-1"></i>{{ article.siteWeb|slice(0, 30) }}...
                      </a>
                    {% endif %}
                  </td>
                  <td>
                    {% if article.articleCategorie %}
                      <span class="badge bg-label-info">{{ article.articleCategorie.intitule }}</span>
                    {% else %}
                      <span class="text-muted">—</span>
                    {% endif %}
                  </td>
                  <td>
                    {% if article.offre %}
                      <span class="badge bg-label-success">{{ article.offre }}</span>
                    {% elseif article.offreCommerciale %}
                      <small class="text-muted">{{ article.offreCommerciale|slice(0, 40) }}...</small>
                    {% else %}
                      <span class="text-muted">—</span>
                    {% endif %}
                  </td>
                  <td>
                    {% if article.departement %}
                      <small>{{ article.departement }}</small>
                    {% else %}
                      <span class="text-muted">—</span>
                    {% endif %}
                  </td>
                  <td>
                    {% if article.utilisateur %}
                      <small>{{ article.utilisateur.prenom }} {{ article.utilisateur.nom }}</small>
                    {% else %}
                      <span class="text-muted">—</span>
                    {% endif %}
                  </td>
                  <td class="text-center">
                    <a href="{{ path('admin_article_show', {id: article.id}) }}"
                       class="btn btn-sm btn-icon btn-outline-primary me-1" title="Voir">
                      <i class="bx bx-show"></i>
                    </a>
                    <a href="{{ path('admin_article_edit', {id: article.id}) }}"
                       class="btn btn-sm btn-icon btn-outline-warning me-1" title="Modifier">
                      <i class="bx bx-edit"></i>
                    </a>
                    <form method="POST"
                          action="{{ path('admin_article_delete', {id: article.id}) }}"
                          class="d-inline"
                          onsubmit="return confirm('Supprimer cet article ?')">
                      <input type="hidden" name="_token"
                             value="{{ csrf_token('delete' ~ article.id) }}">
                      <button type="submit" class="btn btn-sm btn-icon btn-outline-danger" title="Supprimer">
                        <i class="bx bx-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% else %}
        <div class="text-center py-5 text-muted">
          <i class="bx bx-store bx-lg mb-3 d-block"></i>
          <p>Aucun article trouvé.</p>
          <a href="{{ path('admin_article_new') }}" class="btn btn-primary btn-sm">
            Ajouter le premier article
          </a>
        </div>
      {% endif %}
    </div>
  </div>

{% endblock %}
