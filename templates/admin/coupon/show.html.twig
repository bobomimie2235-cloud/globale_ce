{% extends 'admin/layout/base_admin.html.twig' %}
{% block title %}{{ coupon.intitule }}{% endblock %}

{% block body %}

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
      <span class="text-muted fw-light">Admin / <a href="{{ path('admin_coupon_index') }}">Coupons</a> /</span>
      {{ coupon.intitule }}
    </h4>
    <div class="d-flex gap-2">
      <a href="{{ path('admin_coupon_edit', {id: coupon.id}) }}" class="btn btn-warning">
        <i class="bx bx-edit me-1"></i> Modifier
      </a>
      <a href="{{ path('admin_coupon_index') }}" class="btn btn-outline-secondary">
        <i class="bx bx-arrow-back me-1"></i> Retour
      </a>
    </div>
  </div>

  <div class="row">

    {# ===== Colonne gauche ===== #}
    <div class="col-md-4 mb-4">

      {# Logo #}
      <div class="card mb-4">
        <div class="card-header">
          <h6 class="mb-0"><i class="bx bx-image me-2 text-primary"></i>Logo</h6>
        </div>
        <div class="card-body text-center">
          {% if coupon.logo %}
            <img src="{{ asset('uploads/logos/' ~ coupon.logo) }}"
                 alt="{{ coupon.intitule }}"
                 class="img-fluid rounded" style="max-height:150px;">
          {% else %}
            <div class="py-3 text-muted">
              <i class="bx bx-purchase-tag bx-lg"></i>
              <p class="small mb-0 mt-2">Aucun logo</p>
            </div>
          {% endif %}
        </div>
      </div>

      {# Statut #}
      <div class="card mb-4">
        <div class="card-header">
          <h6 class="mb-0"><i class="bx bx-toggle-left me-2 text-info"></i>Statut</h6>
        </div>
        <div class="card-body text-center">
          {% if coupon.actif %}
            <span class="badge bg-success fs-6 px-4 py-2">
              <i class="bx bx-check me-1"></i> Actif
            </span>
          {% else %}
            <span class="badge bg-danger fs-6 px-4 py-2">
              <i class="bx bx-x me-1"></i> Inactif
            </span>
          {% endif %}
        </div>
      </div>

      {# Zone dangereuse #}
      <div class="card border-danger">
        <div class="card-header bg-label-danger">
          <h6 class="mb-0 text-danger"><i class="bx bx-trash me-2"></i>Zone dangereuse</h6>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">La suppression est irréversible.</p>
          <form method="POST"
                action="{{ path('admin_coupon_delete', {id: coupon.id}) }}"
                onsubmit="return confirm('Supprimer définitivement ce coupon ?')">
            <input type="hidden" name="_token"
                   value="{{ csrf_token('delete' ~ coupon.id) }}">
            <button type="submit" class="btn btn-danger w-100">
              <i class="bx bx-trash me-1"></i> Supprimer
            </button>
          </form>
        </div>
      </div>

    </div>

    {# ===== Colonne droite ===== #}
    <div class="col-md-8">

      {# Informations principales #}
      <div class="card mb-4">
        <div class="card-header">
          <h5 class="mb-0"><i class="bx bx-purchase-tag me-2 text-primary"></i>Informations</h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <p class="text-muted small mb-1">Référence</p>
              <p><code class="fs-6">{{ coupon.reference }}</code></p>
            </div>
            <div class="col-md-6">
              <p class="text-muted small mb-1">Intitulé</p>
              <p class="fw-semibold">{{ coupon.intitule }}</p>
            </div>
            <div class="col-md-6">
              <p class="text-muted small mb-1">Catégorie</p>
              <p>
                {% if coupon.couponCategorie %}
                  <span class="badge bg-label-info">{{ coupon.couponCategorie.categorie }}</span>
                {% else %}
                  <span class="text-muted">—</span>
                {% endif %}
              </p>
            </div>
            <div class="col-md-6">
              <p class="text-muted small mb-1">Offre</p>
              <p>
                {% if coupon.offre %}
                  <span class="badge bg-label-success fs-6">{{ coupon.offre }}</span>
                {% else %}
                  <span class="text-muted">—</span>
                {% endif %}
              </p>
            </div>
            <div class="col-md-6">
              <p class="text-muted small mb-1">Ville</p>
              <p>{{ coupon.ville ?: '—' }}</p>
            </div>
            <div class="col-md-6">
              <p class="text-muted small mb-1">Adresse</p>
              <p>{{ coupon.adresse ?: '—' }}</p>
            </div>
            <div class="col-md-6">
              <p class="text-muted small mb-1">Département</p>
              <p>{{ coupon.departement ?? '—' }}</p>
            </div>
            <div class="col-md-6">
              <p class="text-muted small mb-1">Article lié</p>
              <p>
                {% if coupon.article %}
                  <a href="{{ path('admin_article_show', {id: coupon.article.id}) }}">
                    {{ coupon.article.titre }}
                  </a>
                {% else %}
                  <span class="text-muted">—</span>
                {% endif %}
              </p>
            </div>
            <div class="col-12">
              <p class="text-muted small mb-1">Offre commerciale</p>
              <p>{{ coupon.offreCommerciale ?: '—' }}</p>
            </div>
          </div>
        </div>
      </div>

      {# Utilisateurs ayant ce coupon #}
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><i class="bx bx-group me-2 text-warning"></i>Utilisations</h5>
          <span class="badge bg-label-warning">{{ coupon.utilisateurCoupons|length }}</span>
        </div>
        <div class="card-body p-0">
          {% if coupon.utilisateurCoupons is not empty %}
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Utilisateur</th>
                    <th>Utilisé</th>
                    <th>Date utilisation</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {% for uc in coupon.utilisateurCoupons %}
                    <tr>
                      <td>
                        {% if uc.utilisateur %}
                          <strong>{{ uc.utilisateur.prenom }} {{ uc.utilisateur.nom }}</strong>
                          <br><small class="text-muted">{{ uc.utilisateur.email }}</small>
                        {% else %}
                          <span class="text-muted">—</span>
                        {% endif %}
                      </td>
                      <td>
                        {% if uc.utilise %}
                          <span class="badge bg-label-success">Oui</span>
                        {% else %}
                          <span class="badge bg-label-secondary">Non</span>
                        {% endif %}
                      </td>
                      <td>
                        <small>{{ uc.dateUtilisation ? uc.dateUtilisation|date('d/m/Y') : '—' }}</small>
                      </td>
                      <td>
                        {% if uc.utilisateur %}
                          <a href="{{ path('admin_utilisateur_show', {id: uc.utilisateur.id}) }}"
                             class="btn btn-sm btn-icon btn-outline-primary" title="Voir l'utilisateur">
                            <i class="bx bx-show"></i>
                          </a>
                        {% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% else %}
            <div class="text-center py-4 text-muted">
              <i class="bx bx-group bx-md mb-2 d-block"></i>
              <p class="mb-0">Aucune utilisation pour ce coupon.</p>
            </div>
          {% endif %}
        </div>
      </div>

    </div>
  </div>

{% endblock %}
