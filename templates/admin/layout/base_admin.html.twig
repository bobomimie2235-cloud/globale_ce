{% set theme = app.request.cookies.get('admin_theme', 'light') %}

<!DOCTYPE html>
<html
  lang="fr"
  class="layout-navbar-fixed layout-menu-fixed"
  dir="ltr"
  data-skin="default"
  data-bs-theme="{{ theme }}"
  data-theme="theme-default"
  data-assets-path="{{ asset('admin/') }}"
  data-template="vertical-menu-template-free"
>
  <head>
    {# Anti-flash : doit être le PREMIER script, avant tout CSS #}
    <script>
      (function() {
        function getCookie(n) {
          var m = document.cookie.match(new RegExp('(^| )' + n + '=([^;]+)'));
          return m ? m[2] : null;
        }
        var t = getCookie('admin_theme') || 'light';
        document.documentElement.setAttribute('data-bs-theme', t);
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>{% block title %}Dashboard Admin{% endblock %} | {{ site_name ?? 'Mon Site' }}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="{{ asset('admin/img/favicon/favicon.ico') }}" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />

    <!-- Icons Boxicons -->
    <link rel="stylesheet" href="{{ asset('admin/vendor/fonts/boxicons.css') }}" />

    <!-- Core CSS Sneat -->
    <link rel="stylesheet" href="{{ asset('admin/vendor/css/core.css') }}" class="template-customizer-core-css" />
    <link rel="stylesheet" href="{{ asset('admin/vendor/css/theme-default.css') }}" class="template-customizer-theme-css" />
    <link rel="stylesheet" href="{{ asset('admin/css/demo.css') }}" />

    <!-- Vendors CSS -->
    <link rel="stylesheet" href="{{ asset('admin/vendor/libs/perfect-scrollbar/perfect-scrollbar.css') }}" />

    {% block stylesheets %}{% endblock %}

    <!-- Helpers -->
    <script src="{{ asset('admin/vendor/js/helpers.js') }}"></script>
    <!-- Config Sneat (doit être en <head> APRÈS helpers.js) -->
    <script src="{{ asset('admin/js/config.js') }}"></script>
  </head>

  <body>

    <!-- Layout wrapper -->
    <div class="layout-wrapper layout-content-navbar">
      <div class="layout-container">

        {# ===== SIDEBAR ===== #}
        {{ include('admin/partials/_sidebar.html.twig') }}

        {# ===== LAYOUT PAGE (navbar + contenu) ===== #}
        <div class="layout-page">

          {# ===== NAVBAR TOP ===== #}
          {{ include('admin/partials/_navbar.html.twig') }}

          {# ===== CONTENU PRINCIPAL ===== #}
          <div class="content-wrapper">

            {# Flash messages #}
            <div class="container-xxl flex-grow-1 container-p-y">
              {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible mb-3" role="alert">
                  ✅ {{ message }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endfor %}
              {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible mb-3" role="alert">
                  ❌ {{ message }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endfor %}
              {% for message in app.flashes('warning') %}
                <div class="alert alert-warning alert-dismissible mb-3" role="alert">
                  ⚠️ {{ message }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endfor %}
              {% for message in app.flashes('info') %}
                <div class="alert alert-info alert-dismissible mb-3" role="alert">
                  ℹ️ {{ message }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endfor %}
            </div>

            {# Le contenu de chaque page #}
            <div class="container-xxl flex-grow-1 container-p-y">
              {% block body %}{% endblock %}
            </div>

            {# Footer admin #}
            <footer class="content-footer footer bg-footer-theme">
              <div class="container-xxl d-flex flex-wrap justify-content-between py-2 flex-md-row flex-column">
                <div class="mb-2 mb-md-0">
                  © {{ "now"|date("Y") }} — Administration
                </div>
              </div>
            </footer>

            <div class="content-backdrop fade"></div>
          </div>
          {# /content-wrapper #}

        </div>
        {# /layout-page #}

      </div>
      {# /layout-container #}

      <!-- Overlay -->
      <div class="layout-overlay layout-menu-toggle"></div>

    </div>
    {# /layout-wrapper #}

    {# ===== SCRIPTS JS ===== #}
    <!-- jQuery -->
    <script src="{{ asset('admin/vendor/libs/jquery/jquery.js') }}"></script>
    <!-- Popper -->
    <script src="{{ asset('admin/vendor/libs/popper/popper.js') }}"></script>
    <!-- Bootstrap JS -->
    <script src="{{ asset('admin/vendor/js/bootstrap.js') }}"></script>
    <!-- Perfect Scrollbar -->
    <script src="{{ asset('admin/vendor/libs/perfect-scrollbar/perfect-scrollbar.js') }}"></script>
    <!-- Menu JS Sneat -->
    <script src="{{ asset('admin/vendor/js/menu.js') }}"></script>
    <!-- Main JS Sneat -->
    <script src="{{ asset('admin/js/main.js') }}"></script>

    {# ===== THEME TOGGLE ===== #}
    <script>
      (function () {
        function getCookie(name) {
          const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
          return match ? match[2] : null;
        }

        function setCookie(name, value, days) {
          const d = new Date();
          d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
          document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/';
        }

        function applyTheme(theme) {
          document.documentElement.setAttribute('data-bs-theme', theme);
          setCookie('admin_theme', theme, 365);
          const icon = document.getElementById('theme-icon');
          if (icon) {
            icon.className = theme === 'dark' ? 'bx bx-moon fs-5' : 'bx bx-sun fs-5';
          }
        }

        // Appliquer le thème sauvegardé au chargement
        const saved = getCookie('admin_theme') || 'light';
        applyTheme(saved);

        // Attacher le listener sur le bouton
        document.addEventListener('DOMContentLoaded', function () {
          const btn = document.getElementById('theme-toggle');
          if (!btn) return;
          btn.addEventListener('click', function () {
            const current = document.documentElement.getAttribute('data-bs-theme');
            applyTheme(current === 'dark' ? 'light' : 'dark');
          });
        });
      })();
    </script>

    {% block javascripts %}{% endblock %}

  </body>
</html>
