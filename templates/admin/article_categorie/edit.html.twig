{% extends 'admin/layout/base_admin.html.twig' %}
{% block title %}Modifier {{ categorie.intitule }}{% endblock %}

{% block body %}

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
      <span class="text-muted fw-light">Admin / <a href="{{ path('admin_article_index') }}">Offre Commerçant</a> /
      <a href="{{ path('admin_article_categorie_index') }}">Catégories</a> /
      <a href="{{ path('admin_article_categorie_show', {id: categorie.id}) }}">{{ categorie.intitule }}</a> /</span>
      Modifier
    </h4>
    <div class="d-flex gap-2">
      <a href="{{ path('admin_article_categorie_show', {id: categorie.id}) }}" class="btn btn-outline-primary">
        <i class="bx bx-show me-1"></i> Voir
      </a>
      <a href="{{ path('admin_article_categorie_index') }}" class="btn btn-outline-secondary">
        <i class="bx bx-arrow-back me-1"></i> Retour
      </a>
    </div>
  </div>

  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0"><i class="bx bx-tag me-2 text-warning"></i>Modifier la catégorie</h5>
        </div>
        <div class="card-body">
          {{ form_start(form) }}
            <div class="mb-3">
              <label class="form-label">{{ form_label(form.intitule) }}</label>
              {{ form_widget(form.intitule, {'attr': {'class': 'form-control'}}) }}
              {{ form_errors(form.intitule) }}
            </div>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-warning">
                <i class="bx bx-save me-1"></i> Enregistrer
              </button>
              <a href="{{ path('admin_article_categorie_index') }}" class="btn btn-outline-secondary">
                Annuler
              </a>
            </div>
          {{ form_end(form) }}
        </div>
      </div>
    </div>
  </div>

{% endblock %}
