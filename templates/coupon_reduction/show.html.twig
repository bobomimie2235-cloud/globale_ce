{% extends 'base.html.twig' %}

{% block title %}
	{{ coupon_reduction.intitule }}
{% endblock %}

{% block body %}
	<section class="article-show">
		<div
			class="article-show-container">

			{# ===== FLASH MESSAGES ===== #}
			{% if app.flashes('success') is not empty %}
				<div id="modalSucces" style="display:flex; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center; z-index:1000;">
					<div style="background:#fff; padding:2rem; border-radius:8px; max-width:500px; width:90%; text-align:center;">
						<h3 style="color:green;">✅ Succès !</h3>
						{% for message in app.flashes('success') %}
							<p>{{ message }}</p>
						{% endfor %}
						<button onclick="document.getElementById('modalSucces').style.display='none'" class="btn btn-success">Fermer</button>
					</div>
				</div>
			{% endif %}

			{% for message in app.flashes('warning') %}
				<div class="alert alert-warning">{{ message }}</div>
			{% endfor %}
			{% for message in app.flashes('error') %}
				<div class="alert alert-danger">{{ message }}</div>
			{% endfor %}

			{# ===== BOUTON FERMER ===== #}
			<div class="article-show-close">
				<a href="{{ path('app_coupon_reduction_index') }}" class="btn-close-show">✕</a>
			</div>

			<div
				class="article-show-content">

				{# ===== COLONNE GAUCHE : IMAGE ===== #}
				<div class="article-show-images">
					{% if coupon_reduction.logo %}
						<div class="article-show-logo">
							<img src="{{ asset('uploads/logos/' ~ coupon_reduction.logo) }}" alt="{{ coupon_reduction.intitule }}">
						</div>
					{% else %}
						<div class="article-show-logo">
							<span style="font-size: 4rem;">🎫</span>
						</div>
					{% endif %}
				</div>

				{# ===== COLONNE DROITE : INFOS ===== #}
				<div class="article-show-infos">

					<h1 class="article-show-titre">{{ coupon_reduction.intitule }}</h1>

					{% if coupon_reduction.couponCategorie %}
						<p class="article-show-gerant">
							Offre gérée par
							<strong>{{ coupon_reduction.couponCategorie.categorie }}</strong>
						</p>
					{% endif %}

					<ul class="article-show-details">

						{% if coupon_reduction.offreCommerciale %}
							<li>
								<span class="detail-icon">☆</span>
								<div class="detail-text">
									<strong>{{ coupon_reduction.offreCommerciale }}</strong>
								</div>
							</li>
						{% endif %}

						{% if coupon_reduction.ville %}
							<li>
								<span class="detail-icon">🏙️</span>
								<span class="detail-text">
									<strong>{{ coupon_reduction.ville }}</strong>
								</span>
							</li>
						{% endif %}

						{% if coupon_reduction.adresse %}
							<li>
								<span class="detail-icon">📍</span>
								<div class="detail-text">
									<a href="https://maps.google.com/?q={{ coupon_reduction.adresse }}" target="_blank" class="detail-link">
										{{ coupon_reduction.adresse }}
									</a>
									<span class="detail-hint">Cliquer pour voir l'itinéraire</span>
								</div>
							</li>
						{% endif %}

                        {% if is_granted('ROLE_ADMIN') %}
						<li>
							<span class="detail-icon">📌</span>
							<span class="detail-text">
								{% if coupon_reduction.actif %}
									<strong style="color: green;">Coupon actif</strong>
								{% else %}
									<strong style="color: #6c757d;">Coupon inactif</strong>
								{% endif %}
							</span>
						</li>
                        {% endif %}

						<li>
							<span class="detail-icon">🔖</span>
							<span class="detail-text">Réf.
								{{ coupon_reduction.reference }}</span>
						</li>

					</ul>

					{# ===== BOUTONS UTILISATEUR ===== #}
					{% if is_granted('ROLE_USER') and not is_granted('ROLE_ADMIN') %}

						{% set monCoupon = null %}
						{% for uc in coupon_reduction.utilisateurCoupons %}
							{% if uc.utilisateur == app.user %}
								{% set monCoupon = uc %}
							{% endif %}
						{% endfor %}

						{% if monCoupon is null or monCoupon.utilise == false %}

							<button class="btn-panier-green" onclick="document.getElementById('modalUtiliserCoupon').style.display='flex'">
								🎫 Utiliser le coupon
							</button>

							{# ===== MODALE CONFIRMATION ===== #}
							<div id="modalUtiliserCoupon" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center; z-index:1000;">
								<div style="background:#fff; padding:2rem; border-radius:12px; max-width:500px; width:90%;">
									<h5 style="margin-bottom:1rem;">Utiliser le coupon</h5>
									<p>
										<strong>Offre :</strong>
										{{ coupon_reduction.offreCommerciale }}</p>
									<p style="color:#666; font-size:0.9rem;">Êtes-vous sûr ? Cette action est irréversible.</p>
									<div style="display:flex; gap:1rem; margin-top:1.5rem;">
										<button onclick="document.getElementById('modalUtiliserCoupon').style.display='none'" style="flex:1; padding:0.6rem; border:2px solid #ccc; border-radius:50px; background:none; cursor:pointer;">
											Annuler
										</button>
										<form method="post" action="{{ path('app_coupon_reduction_utiliser_mon_coupon', {'id': coupon_reduction.id}) }}" style="flex:1;">
											<input type="hidden" name="_token" value="{{ csrf_token('utiliser-mon-coupon' ~ coupon_reduction.id) }}">
											<button class="btn-panier-green" type="submit" class="btn-panier" style="width:100%;">Confirmer</button>
										</form>
									</div>
								</div>
							</div>

						{% else %}
							<p class="produit-rupture">
								✅ Coupon déjà utilisé le
								{{ monCoupon.dateUtilisation|date('d/m/Y') }}
							</p>
						{% endif %}

					{% endif %}

					{# ===== ACTIONS ADMIN ===== #}
					{% if is_granted('ROLE_ADMIN') %}
						<div class="article-show-admin">
							<a href="{{ path('app_coupon_reduction_edit', {'id': coupon_reduction.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
							<a href="{{ path('app_coupon_reduction_valider_page', {'id': coupon_reduction.id}) }}" class="btn btn-primary btn-sm">Gérer les validations</a>
							{{ include('coupon_reduction/_delete_form.html.twig') }}
						</div>
					{% endif %}

				</div>
			</div>
		</div>
	</section>
{% endblock %}
