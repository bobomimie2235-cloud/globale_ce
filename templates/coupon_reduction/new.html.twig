{% extends 'base.html.twig' %}

{% block title %}Nouveau Coupon Réduction{% endblock %}

{% block body %}
<section class="auth-page">
    <div class="auth-container auth-container--lg">
        <div class="auth-card">

            <a href="{{ path('app_coupon_reduction_index') }}" class="auth-back">← Retour à la liste</a>

            <h1 class="auth-titre">Nouveau Coupon</h1>
            <p class="auth-subtitle">Créer un nouveau coupon réduction</p>

            {% if is_granted('ROLE_ADMIN') %}
                {{ include('coupon_reduction/_form.html.twig', {'button_label': 'Créer le coupon'}) }}
            {% else %}
                <p class="auth-warning">Vous n'avez pas les droits pour créer un coupon.</p>
            {% endif %}

        </div>
    </div>
</section>
{% endblock %}
