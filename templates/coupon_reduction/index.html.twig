{% extends 'base.html.twig' %}

{% block title %}Coupons Réduction{% endblock %}

{% block body %}
<section class="articles-page">
    <div class="articles-container">

        <h1 class="articles-titre">Offres
            <span>Coupons Réduction</span>
        </h1>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="articles-admin-bar">
                <a href="{{ path('app_coupon_reduction_new') }}" class="btn btn-primary btn-sm">+ Créer un coupon</a>
            </div>
        {% endif %}

        <div class="articles-layout">

            {# ===== SIDEBAR FILTRES ===== #}
            <aside class="articles-sidebar">
                <form method="GET" action="{{ path('app_coupon_reduction_index') }}" id="form-filtres">

                <div class="sidebar-search">
    <input type="text"
           name="search"
           id="sidebar-search-input"
           placeholder="Rechercher..."
           value="{{ search ?? '' }}"
           class="sidebar-search-input">
</div>
<hr class="sidebar-divider">

                    {# ----- CATÉGORIES ----- #}
                    <div class="sidebar-bloc">
                        <button type="button"
                                class="sidebar-accordion-toggle"
                                aria-expanded="true"
                                aria-controls="bloc-categories">
                            <h3>Catégories</h3>
                            <span class="sidebar-accordion-icon">▾</span>
                        </button>

                        <ul id="bloc-categories" class="sidebar-accordion-content">
                            {% for categorie in categories %}
                                <li>
                                    <label class="sidebar-checkbox-label">
                                        <input type="checkbox"
                                               name="categories[]"
                                               value="{{ categorie.id }}"
                                               {% if categorie.id in categoriesActives %}checked{% endif %}>
                                        <span>{{ categorie.categorie }}</span>
                                    </label>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>

                    <hr class="sidebar-divider">

                    {# ----- DÉPARTEMENTS ----- #}
                    <div class="sidebar-bloc">
                        <button type="button"
                                class="sidebar-accordion-toggle"
                                aria-expanded="true"
                                aria-controls="bloc-departements">
                            <h3>Départements</h3>
                            <span class="sidebar-accordion-icon">▾</span>
                        </button>

                        <ul id="bloc-departements" class="sidebar-accordion-content">
                            {% for departement in departements %}
                                <li>
                                    <label class="sidebar-checkbox-label">
                                        <input type="checkbox"
                                               name="departements[]"
                                               value="{{ departement.id }}"
                                               {% if departement.id in departementsActifs %}checked{% endif %}>
                                        <span>{{ departement.numero }} - {{ departement.nom }}</span>
                                    </label>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>

                    {# ----- RESET ----- #}
                    <div class="sidebar-actions" id="sidebar-reset-wrap" style="display:none">
                        <a href="{{ path('app_coupon_reduction_index') }}"
                           class="btn btn-secondary btn-sm btn-block">
                            ✕ Réinitialiser
                        </a>
                    </div>

                </form>
            </aside>

            {# ===== GRILLE (cible AJAX) ===== #}
            <div class="articles-main" id="articles-main">
                {% include 'coupon_reduction/_grille.html.twig' %}
            </div>

        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {

    const form        = document.getElementById('form-filtres');
    const main        = document.getElementById('articles-main');
    const resetWrap   = document.getElementById('sidebar-reset-wrap');
    const searchInput = document.getElementById('sidebar-search-input');
    const baseUrl     = form.getAttribute('action');
    let debounceTimer = null;

    function setLoading(on) {
        main.style.opacity       = on ? '0.4' : '1';
        main.style.pointerEvents = on ? 'none' : '';
    }

    function buildUrl() {
        const params = new URLSearchParams();
        // Checkboxes cochées
        form.querySelectorAll('input[type="checkbox"]:checked').forEach(function (cb) {
            params.append(cb.name, cb.value);
        });
        // Champ search
        const q = searchInput ? searchInput.value.trim() : '';
        if (q) params.set('search', q);

        return params.toString() ? baseUrl + '?' + params.toString() : baseUrl;
    }

    function updateResetBtn() {
        const hasChecked = form.querySelectorAll('input:checked').length > 0;
        const hasSearch  = searchInput && searchInput.value.trim().length > 0;
        resetWrap.style.display = (hasChecked || hasSearch) ? 'block' : 'none';
    }

    function fetchGrille() {
        setLoading(true);
        fetch(buildUrl(), {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(res => res.text())
        .then(html => { main.innerHTML = html; setLoading(false); })
        .catch(() => setLoading(false));
    }

    // Checkboxes → fetch immédiat (debounce 200ms)
    form.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
        cb.addEventListener('change', function () {
            updateResetBtn();
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(fetchGrille, 200);
        });
    });

    // Champ search → fetch avec debounce 400ms (laisse taper)
    if (searchInput) {
        searchInput.addEventListener('input', function () {
            updateResetBtn();
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(fetchGrille, 400);
        });
    }

    // Accordion toggle
    document.querySelectorAll('.sidebar-accordion-toggle').forEach(function (btn) {
        const content = document.getElementById(btn.getAttribute('aria-controls'));
        const icon    = btn.querySelector('.sidebar-accordion-icon');

        btn.addEventListener('click', function () {
            const isOpen = btn.getAttribute('aria-expanded') === 'true';
            if (isOpen) {
                content.setAttribute('hidden', '');
                btn.setAttribute('aria-expanded', 'false');
                icon.textContent = '▾';
            } else {
                content.removeAttribute('hidden');
                btn.setAttribute('aria-expanded', 'true');
                icon.textContent = '▴';
            }
        });
    });

    updateResetBtn();
});
</script>
{% endblock %}
