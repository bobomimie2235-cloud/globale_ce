{% extends 'base.html.twig' %}

{% block title %}Coupons Réduction
{% endblock %}

{% block body %}
	<section class="articles-page">
		<div class="articles-container">

			<h1 class="articles-titre">Offres
				<span>Coupons Réduction</span>
			</h1>

			{% if is_granted('ROLE_ADMIN') %}
				<div class="articles-admin-bar">
					<a href="{{ path('app_coupon_reduction_new') }}" class="btn btn-primary btn-sm">+ Créer un coupon</a>
				</div>
			{% endif %}

			<div
				class="articles-layout">

				{# ===== SIDEBAR CATÉGORIES ===== #}
				<aside class="articles-sidebar">
					<div class="sidebar-header">
						<h3>Catégories</h3>
						<button class="sidebar-toggle" id="sidebar-toggle" aria-label="Afficher/Masquer">
							<span id="sidebar-toggle-label">Afficher ▾</span>
						</button>
					</div>

					<span class="sidebar-active-label">
						{% if categorieActive is null %}
							Toutes les offres
						{% else %}
							{% for categorie in categories %}
								{% if categorieActive == categorie.id %}
									{{ categorie.categorie }}
								{% endif %}
							{% endfor %}
						{% endif %}
					</span>

					<ul id="sidebar-menu">
						<li>
							<a href="{{ path('app_coupon_reduction_index') }}" class="{{ categorieActive is null ? 'active' : '' }}">
								Toutes les offres
							</a>
						</li>
						{% for categorie in categories %}
							<li>
								<a href="{{ path('app_coupon_reduction_index') }}?categorie={{ categorie.id }}" class="{{ categorieActive == categorie.id ? 'active' : '' }}">
									{{ categorie.categorie }}
								</a>
							</li>
						{% endfor %}
					</ul>
				</aside>

				{# ===== GRILLE COUPONS ===== #}
				<div class="articles-main">
					{% if coupon_reductions is empty %}
						<div class="articles-empty">
							<p>Aucun coupon disponible pour le moment.</p>
						</div>
					{% else %}
						<div class="articles-grid">
							{% for coupon in coupon_reductions %}
								<div
									class="article-card">

									{# ===== BADGE OFFRE ===== #}
									{% if coupon.offre %}
										<div class="article-card-badge">{{ coupon.offre }}</div>
									{% endif %}

									{# ===== BADGE INACTIF ===== #}
									{% if not coupon.actif %}
										<div class="article-card-badge" style="background: #6c757d;">Inactif</div>
									{% endif %}

									{# ===== IMAGE ===== #}
									<a href="{{ path('app_coupon_reduction_show', {'id': coupon.id}) }}">
										<div class="article-card-img">
											{% if coupon.logo %}
												<img src="{{ asset('uploads/logos/' ~ coupon.logo) }}" alt="{{ coupon.intitule }}">
											{% else %}
												<div class="article-card-img-placeholder">🎫</div>
											{% endif %}
										</div>
									</a>

									{# ===== CATÉGORIE ===== #}
									{% if coupon.couponCategorie %}
										<div class="article-card-categorie">
											🏷️
											{{ coupon.couponCategorie.categorie }}
										</div>
									{% endif %}

									{# ===== CORPS ===== #}
									<div class="article-card-body">
										<h3 class="article-card-titre">{{ coupon.intitule }}</h3>

										<p class="article-card-desc">
											{{ coupon.ville }}
										</p>

										<hr class="article-card-divider">

										<a href="{{ path('app_coupon_reduction_show', {'id': coupon.id}) }}" class="article-card-link">Voir la fiche</a>

										{% if is_granted('ROLE_ADMIN') %}
											<div class="article-card-admin">
												<a href="{{ path('app_coupon_reduction_edit', {'id': coupon.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
												<form method="post" action="{{ path('app_coupon_reduction_delete', {'id': coupon.id}) }}" onsubmit="return confirm('Supprimer ce coupon ?');" style="display:inline;">
													<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ coupon.id) }}">
													<button class="btn btn-danger btn-sm">Supprimer</button>
												</form>
											</div>
										{% endif %}
									</div>

								</div>
							{% endfor %}
						</div>
					{% endif %}
				</div>

			</div>
		</div>
	</section>
{% endblock %}
