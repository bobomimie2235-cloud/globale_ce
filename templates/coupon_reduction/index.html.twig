{% extends 'base.html.twig' %}

{% block title %}CouponReduction index{% endblock %}

{% block body %}
    <h1>CouponReduction index</h1>

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_coupon_reduction_new') }}" class="btn btn-primary btn-sm">Créer un coupon</a>
    {% endif %}

    <table class="table">
        <thead>
            <tr>
                <th>Logo</th>
                <th>Id</th>
                <th>Référence</th>
                <th>Intitulé</th>
                <th>Coupon Catégorie</th>
                <th>Ville</th>
                <th>Adresse</th>
                <th>Offre Commerciale</th>
                <th>Actif</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for coupon_reduction in coupon_reductions %}
            <tr>
            <td>
						{% if coupon_reduction.logo %}
							<img src="{{ asset('uploads/logos/' ~ coupon_reduction.logo) }}" alt="Logo" style="max-height: 80px;">
						{% else %}
							-
						{% endif %}
					</td>
                <td>{{ coupon_reduction.id }}</td>
                <td>{{ coupon_reduction.reference }}</td>
                <td>{{ coupon_reduction.intitule }}</td>
                <td>{{ coupon_reduction.couponCategorie ? coupon_reduction.couponCategorie.categorie : '-' }}</td>
                <td>{{ coupon_reduction.ville }}</td>
                <td>{{ coupon_reduction.adresse }}</td>
                <td>{{ coupon_reduction.offreCommerciale }}</td>
                <td>
                    {% if coupon_reduction.actif %}
                        <span class="badge bg-success">Actif</span>
                    {% else %}
                        <span class="badge bg-secondary">Inactif</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_coupon_reduction_show', {'id': coupon_reduction.id}) }}" class="btn btn-info btn-sm">Voir</a>

                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_coupon_reduction_edit', {'id': coupon_reduction.id}) }}" class="btn btn-warning btn-sm">Modifier</a>

                        <form method="post" action="{{ path('app_coupon_reduction_delete', {'id': coupon_reduction.id}) }}"
                            onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce coupon ?');"
                            style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ coupon_reduction.id) }}">
                            <button class="btn btn-danger btn-sm">Supprimer</button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucun coupon trouvé.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}