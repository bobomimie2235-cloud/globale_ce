{% extends 'base.html.twig' %}

{% block title %}Profil
{% endblock %}

{% block body %}
	<section class="profil-page">
		<div
			class="profil-container">

			{# ===== INFORMATIONS PERSONNELLES ===== #}
			<div class="profil-card">
				<div class="profil-card__header">
					<h1 class="profil-titre">Mon profil</h1>
					<div class="profil-card__actions">
						<a href="{{ path('app_utilisateur_edit', {'id': app.user.id}) }}" class="btn btn-warning btn-sm">✏️ Modifier</a>
					</div>
				</div>

				<table class="profil-table">
					<tbody>
						<tr>
							<th>Email</th>
							<td>{{ app.user.email }}</td>
						</tr>
						<tr>
							<th>Nom</th>
							<td>{{ app.user.nom }}</td>
						</tr>
						<tr>
							<th>Prénom</th>
							<td>{{ app.user.prenom }}</td>
						</tr>
						<tr>
							<th>Inscription</th>
							<td>{{ app.user.dateInscription|date('d/m/Y') }}</td>
						</tr>
						<tr>
							<th>Groupe</th>
							<td>{{ app.user.utilisateurGroupe ? app.user.utilisateurGroupe.nomGroupe : '-' }}</td>
						</tr>
					</tbody>
				</table>
			</div>

			{# ===== ADRESSES ===== #}
			<div class="profil-card">
				<button class="profil-toggle" data-target="bloc-adresses">
					📍 Mes adresses
					<span class="profil-toggle__icon">▼</span>
				</button>
				<div id="bloc-adresses" class="profil-bloc profil-bloc--hidden">

					{% if adresses is empty %}
						<p class="profil-empty">Aucune adresse enregistrée.</p>
					{% else %}
						<table class="profil-table">
							<thead>
								<tr>
									<th>Adresse</th>
									<th>Code postal</th>
									<th>Ville</th>
								</tr>
							</thead>
							<tbody>
								{% for adresse in adresses %}
									<tr>
										<td>{{ adresse.adresse }}</td>
										<td>{{ adresse.codePostal }}</td>
										<td>{{ adresse.ville }}</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					{% endif %}

					{# Formulaire nouvelle adresse — style auth-card #}
					<div class="auth-card profil-form-card">
						<h3 class="auth-titre">Ajouter une adresse</h3>
						{{ form_start(formAdresse, {'attr': {'class': 'auth-form'}}) }}
						{% for field in formAdresse %}
							<div class="auth-field">
								{{ form_label(field) }}
								{{ form_widget(field) }}
								{{ form_errors(field) }}
							</div>
						{% endfor %}
						<button type="submit" class="btn-auth">Ajouter</button>
						{{ form_end(formAdresse) }}
					</div>

				</div>
			</div>

			{# ===== COMMANDES ===== #}
			<div class="profil-card">
				<button class="profil-toggle" data-target="bloc-commandes">
					🛒 Mes commandes
					<span class="profil-toggle__icon">▼</span>
				</button>
				<div id="bloc-commandes" class="profil-bloc profil-bloc--hidden">

					{% if commandes is defined and commandes is not empty %}
						<table class="profil-table">
							<thead>
								<tr>
									<th>Référence</th>
									<th>Statut</th>
									<th>Total TTC</th>
									<th>Date</th>
									<th>Action</th>
								</tr>
							</thead>
							<tbody>
								{% for commande in commandes %}
									<tr>
										<td>#{{ '%05d'|format(commande.id) }}</td>
										<td>
											<span class="statut-badge statut-{{ commande.statut }}">
												{% if commande.statut == 'validee' %}Validée
													{% elseif commande.statut == 'en_cours' %}En cours
												{% else %}
													{{ commande.statut }}
												{% endif %}
											</span>
										</td>
										<td>{{ commande.totalTTC|number_format(2, ',', ' ') }}
											€</td>
										<td>{{ commande.dateCommande ? commande.dateCommande|date('d/m/Y') : '-' }}</td>
										<td>
											<a href="{{ path('app_commande_show', {'id': commande.id}) }}" class="btn btn-info btn-sm">🧾 Facture</a>
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					{% else %}
						<p class="profil-empty">Aucune commande.</p>
					{% endif %}

				</div>
			</div>

			{# ===== COUPONS ===== #}
			<div class="profil-card">
				<button class="profil-toggle" data-target="bloc-coupons">
					🎟️ Mes coupons utilisés
					<span class="profil-toggle__icon">▼</span>
				</button>
				<div id="bloc-coupons" class="profil-bloc profil-bloc--hidden">

					{% if coupons is not empty %}
						<table class="profil-table">
							<thead>
								<tr>
									<th>Logo</th>
									<th>Référence</th>
									<th>Intitulé</th>
									<th>Offre</th>
									<th>Utilisé le</th>
								</tr>
							</thead>
							<tbody>
								{% for utilisateurCoupon in coupons %}
									<tr>
										<td>
											{% if utilisateurCoupon.couponReduction.logo %}
												<img src="{{ asset('uploads/logos/' ~ utilisateurCoupon.couponReduction.logo) }}" alt="Logo" class="profil-logo">
											{% else %}
												—
											{% endif %}
										</td>
										<td>{{ utilisateurCoupon.couponReduction.reference }}</td>
										<td>{{ utilisateurCoupon.couponReduction.intitule }}</td>
										<td>{{ utilisateurCoupon.couponReduction.offreCommerciale }}</td>
										<td>{{ utilisateurCoupon.dateUtilisation ? utilisateurCoupon.dateUtilisation|date('d/m/Y') : '-' }}</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					{% else %}
						<p class="profil-empty">Aucun coupon utilisé.</p>
					{% endif %}

				</div>
			</div>

			{# ===== SUPPRESSION RGPD ===== #}
<div class="profil-card profil-card--danger">
    <button class="profil-toggle profil-toggle--danger" data-target="bloc-suppression">
        🗑️ Supprimer mon compte
        <span class="profil-toggle__icon">▼</span>
    </button>
    <div id="bloc-suppression" class="profil-bloc profil-bloc--hidden">
        <div class="profil-danger-info">
            <p><strong>⚠️ Cette action est irréversible.</strong></p>
            <p>La suppression de votre compte entraîne la suppression définitive de toutes vos données personnelles conformément au RGPD (droit à l'effacement – article 17).</p>
            <p>Sont supprimées : vos informations personnelles, vos adresses, votre historique de commandes et vos coupons.</p>
        </div>
        <button class="btn btn-danger btn-sm" id="btn-ouvrir-modal-suppression">
            🗑️ Supprimer définitivement mon compte
        </button>
    </div>
</div>

{# ===== MODALE DE CONFIRMATION ===== #}
<div id="modal-suppression" class="modal-overlay" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="modal-titre">
    <div class="modal-box">
        <h2 id="modal-titre">⚠️ Confirmer la suppression</h2>
        <p>Pour confirmer la suppression définitive de votre compte, saisissez votre <strong>mot de passe</strong> :</p>

        <form action="{{ path('app_profil_supprimer') }}" method="POST" id="form-suppression">
            <input type="hidden" name="_token" value="{{ csrf_token('supprimer_compte_' ~ app.user.id) }}">

            <div class="auth-field">
                <label for="mot_de_passe">Mot de passe</label>
                <input
                    type="password"
                    id="mot_de_passe"
                    name="mot_de_passe"
                    required
                    autocomplete="current-password"
                    placeholder="Votre mot de passe actuel"
                    class="form-control"
                >
            </div>

            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" id="btn-annuler-suppression">Annuler</button>
                <button type="submit" class="btn btn-danger">Supprimer définitivement</button>
            </div>
        </form>
    </div>
</div>
		</div>
	</section>
{% endblock %}

{% block scripts_body %}
	<script>
		document.querySelectorAll('.profil-toggle').forEach(btn => {
btn.addEventListener('click', () => {
const target = document.getElementById(btn.dataset.target);
const icon = btn.querySelector('.profil-toggle__icon');
const isOpen = ! target.classList.contains('profil-bloc--hidden');

target.classList.toggle('profil-bloc--hidden', isOpen);
icon.textContent = isOpen ? '▼' : '▲';
});
});

// --- Modale suppression compte ---
const modal = document.getElementById('modal-suppression');
document.getElementById('btn-ouvrir-modal-suppression')?.addEventListener('click', () => {
    modal.style.display = 'flex';
    document.getElementById('mot_de_passe').focus();
});
document.getElementById('btn-annuler-suppression')?.addEventListener('click', () => {
    modal.style.display = 'none';
    document.getElementById('mot_de_passe').value = '';
});
modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
        modal.style.display = 'none';
        document.getElementById('mot_de_passe').value = '';
    }
});
	</script>
{% endblock %}
