{% extends 'base.html.twig' %}

{% block title %}Modifier Catégorie Produit{% endblock %}

{% block body %}
    <h1>Modifier Catégorie Produit</h1>

    {% if is_granted('ROLE_ADMIN') %}
        {{ include('produit_categorie/_form.html.twig', {'button_label': 'Modifier'}) }}
    {% else %}
