{% extends 'base.html.twig' %}

{% block title %}Catégorie Produit{% endblock %}

{% block body %}
    <h1>Catégorie Produit</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ produit_categorie.id }}</td>
            </tr>
            <tr>
                <th>Intitulé</th>
                <td>{{ produit_categorie.intitule }}</td>
            </tr>
        </tbody>
    </table>

    <a class="btn-return" href="{{ path('app_produit_categorie_index') }}">Retour à la liste</a>

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_produit_categorie_edit', {'id': produit_categorie.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
    {% endif %}

    {{ include('produit_categorie/_delete_form.html.twig') }}
{% endblock %}