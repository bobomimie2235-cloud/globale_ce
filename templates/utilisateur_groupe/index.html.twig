{% extends 'base.html.twig' %}

{% block title %}Gestion des Groupes
{% endblock %}

{% block body %}
	<section class="articles-page">
		<div class="articles-container">

			<h1 class="articles-titre">Gestion des
				<span>Groupes</span>
			</h1>

			{% if is_granted('ROLE_ADMIN') %}
				<div class="articles-admin-bar">
					<a href="{{ path('app_utilisateur_groupe_new') }}" class="btn btn-primary btn-sm">+ Créer un groupe</a>
				</div>
			{% endif %}

			<div class="groupes-table-wrap">
				<table class="groupes-table">
					<thead>
						<tr>
							<th>Nom groupe</th>
							<th>Adresse</th>
							<th>Code postal</th>
							<th>Ville</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for groupe in utilisateur_groupes %}
							<tr>
								<td class="groupes-nom">{{ groupe.nomGroupe }}</td>
								<td>{{ groupe.adresse }}</td>
								<td class="groupes-cp">{{ groupe.codePostal }}</td>
								<td>{{ groupe.ville }}</td>
								<td class="groupes-actions">
									<a href="{{ path('app_utilisateur_groupe_show', {'id': groupe.id}) }}" class="btn btn-info btn-sm">Voir</a>

									{% if is_granted('ROLE_ADMIN') %}
										<a href="{{ path('app_utilisateur_groupe_edit', {'id': groupe.id}) }}" class="btn btn-warning btn-sm">Modifier</a>

										<form method="post" action="{{ path('app_utilisateur_groupe_delete', {'id': groupe.id}) }}" onsubmit="return confirm('Supprimer ce groupe ?');" style="display:inline;">
											<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ groupe.id) }}">
											<button class="btn btn-delete btn-sm">Supprimer</button>
										</form>
									{% endif %}
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="9" class="groupes-empty">Aucun groupe trouvé.</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>

		</div>
	</section>
{% endblock %}
