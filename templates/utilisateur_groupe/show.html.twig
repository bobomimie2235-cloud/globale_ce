{% extends 'base.html.twig' %}

{% block title %}Groupe Utilisateur{% endblock %}

{% block body %}
    <h1>Groupe Utilisateur</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ utilisateur_groupe.id }}</td>
            </tr>
            <tr>
                <th>Nom groupe</th>
                <td>{{ utilisateur_groupe.nomGroupe }}</td>
            </tr>
            <tr>
                <th>Référence</th>
                <td>{{ utilisateur_groupe.referenceGroupe }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ utilisateur_groupe.adresse }}</td>
            </tr>
            <tr>
                <th>Code postal</th>
                <td>{{ utilisateur_groupe.codePostal }}</td>
            </tr>
            <tr>
                <th>Ville</th>
                <td>{{ utilisateur_groupe.ville }}</td>
            </tr>
            <tr>
                <th>Téléphone</th>
                <td>{{ utilisateur_groupe.telephone }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ utilisateur_groupe.email }}</td>
            </tr>
        </tbody>
    </table>

    {# ===== Utilisateurs du groupe ===== #}
    <h2>Utilisateurs du groupe</h2>

    {% if utilisateur_groupe.utilisateurs is empty %}
        <p>Aucun utilisateur dans ce groupe.</p>
    {% else %}
        <table class="table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Inscription</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for utilisateur in utilisateur_groupe.utilisateurs %}
                    <tr>
                        <td>{{ utilisateur.id }}</td>
                        <td>{{ utilisateur.nom }}</td>
                        <td>{{ utilisateur.prenom }}</td>
                        <td>{{ utilisateur.email }}</td>
                        <td>{{ utilisateur.dateInscription ? utilisateur.dateInscription|date('d/m/Y') : '-' }}</td>
                        <td>
                            <a href="{{ path('app_utilisateur_show', {'id': utilisateur.id}) }}" class="btn btn-info btn-sm">Voir</a>

                            {% if is_granted('ROLE_ADMIN') or app.user == utilisateur %}
                                <a href="{{ path('app_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                            {% endif %}

                            {% if is_granted('ROLE_ADMIN') %}
                                <form method="post" action="{{ path('app_utilisateur_delete', {'id': utilisateur.id}) }}"
                                    onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');"
                                    style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
                                    <button class="btn btn-danger btn-sm">Supprimer</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <a class="btn btn-return btn-sm" href="{{ path('app_utilisateur_groupe_index') }}">Retour à la liste</a>

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_utilisateur_groupe_edit', {'id': utilisateur_groupe.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
    {% endif %}

    {{ include('utilisateur_groupe/_delete_form.html.twig') }}
{% endblock %}