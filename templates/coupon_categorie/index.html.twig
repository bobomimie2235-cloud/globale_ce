{% extends 'base.html.twig' %}

{% block title %}CouponCategorie index{% endblock %}

{% block body %}
    <h1>CouponCategorie index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Categorie</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for coupon_categorie in coupon_categories %}
            <tr>
                <td>{{ coupon_categorie.id }}</td>
                <td>{{ coupon_categorie.categorie }}</td>
                <td>
                    <a href="{{ path('app_coupon_categorie_show', {'id': coupon_categorie.id}) }}">show</a>
                    <a href="{{ path('app_coupon_categorie_edit', {'id': coupon_categorie.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_coupon_categorie_new') }}">Create new</a>
{% endblock %}
