{% extends 'base.html.twig' %}

{% block title %}Utilisateur Adresse index{% endblock %}

{% block body %}
    <h1>Utilisateur Adresse index</h1>

    <a href="{{ path('app_utilisateur_adresse_new') }}" class="btn btn-primary btn-sm">Ajouter une adresse</a>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Prénom</th>
                <th>Adresse</th>
                <th>Code postal</th>
                <th>Ville</th>
                <th>Pays</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for utilisateur_adresse in utilisateur_adresses %}
            <tr>
                <td>{{ utilisateur_adresse.id }}</td>
                <td>{{ utilisateur_adresse.nom }}</td>
                <td>{{ utilisateur_adresse.prenom }}</td>
                <td>{{ utilisateur_adresse.adresse }}</td>
                <td>{{ utilisateur_adresse.codePostal }}</td>
                <td>{{ utilisateur_adresse.ville }}</td>
                <td>{{ utilisateur_adresse.pays }}</td>
                <td>
                    <a href="{{ path('app_utilisateur_adresse_show', {'id': utilisateur_adresse.id}) }}" class="btn btn-info btn-sm">Voir</a>

                    {% if is_granted('ROLE_ADMIN') or app.user == utilisateur_adresse.utilisateur %}
                        <a href="{{ path('app_utilisateur_adresse_edit', {'id': utilisateur_adresse.id}) }}" class="btn btn-warning btn-sm">Modifier</a>

                        <form method="post" action="{{ path('app_utilisateur_adresse_delete', {'id': utilisateur_adresse.id}) }}"
                            onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette adresse ?');"
                            style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur_adresse.id) }}">
                            <button class="btn btn-danger btn-sm">Supprimer</button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">Aucune adresse trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}