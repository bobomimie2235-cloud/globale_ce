{% extends 'base.html.twig' %}

{% block title %}Ma commande en cours{% endblock %}

{% block body %}
    <h1>Panier</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {% if commande is null or commande.commandeProduits is empty %}
        <p>Votre commande est vide.</p>
        <a href="{{ path('app_produit_index') }}" class="btn btn-primary">Voir la billetterie</a>
    {% else %}
        <table class="table">
            <thead>
                <tr>
                    <th>Produit</th>
                    <th>Prix unitaire</th>
                    <th>Quantité</th>
                    <th>Sous-total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for cp in commande.commandeProduits %}
                    <tr data-cp-id="{{ cp.id }}">
                        <td>{{ cp.produit.intitule }}</td>
                        <td>{{ cp.produit.prixPublic }} €</td>
                        <td>
                            {# ===== Boutons +/- ===== #}
                            <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-outline-secondary btn-sm btn-quantite"
                                        data-id="{{ cp.id }}"
                                        data-action="moins"
                                        {% if cp.quantite <= 1 %}disabled{% endif %}>
                                    −
                                </button>
                                <span class="quantite-valeur fw-bold px-2">{{ cp.quantite }}</span>
                                <button class="btn btn-outline-secondary btn-sm btn-quantite"
                                        data-id="{{ cp.id }}"
                                        data-action="plus"
                                        {% if cp.quantite >= cp.produit.stock %}disabled{% endif %}>
                                    +
                                </button>
                            </div>
                        </td>
                        <td class="sous-total-ligne">
                            {{ (cp.produit.prixPublic * cp.quantite)|number_format(2, ',', ' ') }} €
                        </td>
                        <td>
                            <form method="post"
                                  action="{{ path('app_commande_retirer_produit', {'commandeProduitId': cp.id}) }}"
                                  onsubmit="return confirm('Retirer ce produit ?');">
                                <button type="submit" class="btn btn-danger btn-sm">Retirer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3">Total TTC</th>
                    <th id="total-ttc">{{ commande.totalTTC }} €</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>

        <a href="{{ path('app_produit_index') }}" class="btn btn-secondary btn-retour-achat">Continuer mes achats</a>

        <form method="post" action="{{ path('app_commande_valider') }}" style="display:inline;">
            <input type="hidden" name="_token" value="{{ csrf_token('valider_commande') }}">
            <button type="submit" class="btn btn-success"
                    onclick="return confirm('Confirmer la commande ?');">
                Valider la commande
            </button>
        </form>
    {% endif %}

{% endblock %}

{% block scripts_body %}
<script>
document.querySelectorAll('.btn-quantite').forEach(btn => {
    btn.addEventListener('click', async function () {
        const id     = this.dataset.id;
        const action = this.dataset.action;
        const ligne  = this.closest('tr');

        ligne.querySelectorAll('.btn-quantite').forEach(b => b.disabled = true);

        const formData = new FormData();
        formData.append('action', action);

        try {
            const response = await fetch(
                `/commande/quantite/${id}`,
                { method: 'POST', body: formData }
            );

            if (!response.ok) {
                const err = await response.json();
                alert(err.error ?? 'Erreur lors de la mise à jour.');
                // Réactive les boutons en cas d'erreur
                ligne.querySelectorAll('.btn-quantite').forEach(b => b.disabled = false);
                return;
            }

            const data = await response.json();

            ligne.querySelector('.quantite-valeur').textContent = data.nouvelleQuantite;
            ligne.querySelector('.sous-total-ligne').textContent = data.sousTotalLigne + ' €';
            document.getElementById('total-ttc').textContent = data.totalTTC + ' €';

            // Gère les états disabled selon les nouvelles limites
            ligne.querySelector('[data-action="moins"]').disabled = data.nouvelleQuantite <= 1;
            ligne.querySelector('[data-action="plus"]').disabled  = data.stockAtteint ?? false;

        } catch (e) {
            alert('Erreur réseau.');
            ligne.querySelectorAll('.btn-quantite').forEach(b => b.disabled = false);
        }
    });
});
</script>
{% endblock %}