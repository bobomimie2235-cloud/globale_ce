{% extends 'base.html.twig' %}

{% block title %}Ma commande en cours{% endblock %}

{% block body %}
    <h1>Ma commande en cours</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {% if commande is null or commande.commandeProduits is empty %}
        <p>Votre commande est vide.</p>
        <a href="{{ path('app_produit_index') }}" class="btn btn-primary">Voir la billetterie</a>
    {% else %}
        <table class="table">
            <thead>
                <tr>
                    <th>Produit</th>
                    <th>Prix unitaire</th>
                    <th>Quantité</th>
                    <th>Sous-total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for cp in commande.commandeProduits %}
                    <tr>
                        <td>{{ cp.produit.intitule }}</td>
                        <td>{{ cp.produit.prixPublic }} €</td>
                        <td>{{ cp.quantite }}</td>
                        <td>{{ (cp.produit.prixPublic * cp.quantite)|number_format(2, ',', ' ') }} €</td>
                        <td>
                            <form method="post" action="{{ path('app_commande_retirer_produit', {'commandeProduitId': cp.id}) }}"
                                  onsubmit="return confirm('Retirer ce produit ?');">
                                <button type="submit" class="btn btn-danger btn-sm">Retirer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3">Total TTC</th>
                    <th>{{ commande.totalTTC }} €</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>

        <a href="{{ path('app_produit_index') }}" class="btn btn-secondary">Continuer mes achats</a>

        <form method="post" action="{{ path('app_commande_valider') }}" style="display:inline;">
            <input type="hidden" name="_token" value="{{ csrf_token('valider_commande') }}">
            <button type="submit" class="btn btn-success"
                    onclick="return confirm('Confirmer la commande ?');">
                Valider la commande
            </button>
        </form>
    {% endif %}

{% endblock %}