{% extends 'base.html.twig' %}

{% block title %}Commande index{% endblock %}

{% block body %}
    <h1>Commande index</h1>

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_commande_new') }}" class="btn btn-primary btn-sm">Créer une commande</a>
    {% endif %}

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Statut</th>
                <th>Total TTC</th>
                <th>Date commande</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for commande in commandes %}
            <tr>
                <td>{{ commande.id }}</td>
                <td>{{ commande.statut }}</td>
                <td>{{ commande.totalTTC }} €</td>
                <td>{{ commande.dateCommande ? commande.dateCommande|date('d/m/Y H:i') : '-' }}</td>
                <td>
                    <a href="{{ path('app_commande_show', {'id': commande.id}) }}" class="btn btn-info btn-sm">Voir</a>

                    {% if is_granted('ROLE_ADMIN') or app.user == commande.utilisateur %}
                        <a href="{{ path('app_commande_edit', {'id': commande.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                    {% endif %}

                    {% if is_granted('ROLE_ADMIN') %}
                        <form method="post" action="{{ path('app_commande_delete', {'id': commande.id}) }}"
                            onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette commande ?');"
                            style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commande.id) }}">
                            <button class="btn btn-danger btn-sm">Supprimer</button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucune commande trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}