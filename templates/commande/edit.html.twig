{% extends 'base.html.twig' %}

{% block title %}Modifier Commande{% endblock %}

{% block body %}
    <h1>Modifier Commande</h1>

    {% if is_granted('ROLE_ADMIN') or app.user == commande.utilisateur %}
        {{ include('commande/_form.html.twig', {'button_label': 'Modifier'}) }}
    {% else %}
        <p class="alert alert-warning">Vous n'avez pas les droits pour modifier cette commande.</p>
    {% endif %}

    <a href="{{ path('app_commande_index') }}">Retour à la liste</a>

    {{ include('commande/_delete_form.html.twig') }}
{% endblock %}
