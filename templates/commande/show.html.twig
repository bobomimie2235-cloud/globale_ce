{% extends 'base.html.twig' %}

{% block title %}Commande{% endblock %}

{% block body %}
    <h1>Commande</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ commande.id }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ commande.statut }}</td>
            </tr>
            <tr>
                <th>Total TTC</th>
                <td>{{ commande.totalTTC }} €</td>
            </tr>
            <tr>
                <th>Date commande</th>
                <td>{{ commande.dateCommande ? commande.dateCommande|date('d/m/Y H:i') : '-' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_commande_index') }}">Retour à la liste</a>

    {% if is_granted('ROLE_ADMIN') or app.user == commande.utilisateur %}
        <a href="{{ path('app_commande_edit', {'id': commande.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
    {% endif %}

    {{ include('commande/_delete_form.html.twig') }}
{% endblock %}