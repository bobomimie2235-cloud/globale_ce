{% if not app.session.get('cookies_accepted') %}
<div id="cookie-banner" style="
    position: fixed;
    bottom: 0;
    width: 100%;
    background: #343A40;
    color: white;
    padding: 15px;
    text-align: center;
    z-index: 9999;">

    🍪 Ce site utilise des cookies nécessaires à son fonctionnement 
    (session et authentification).
    
    <button onclick="acceptCookies()" style="
        margin-left: 15px;
        background: #A243F7;
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 5px;
        cursor: pointer;">
        Accepter
    </button>
    
    <a href="{{ path('app_politique_confidentialite') }}" 
       style="color: #ccc; margin-left: 10px;">
        En savoir plus
    </a>
</div>

<script>
function acceptCookies() {
    fetch('{{ path("app_cookies_accept") }}', {method: 'POST'})
    .then(() => {
        document.getElementById('cookie-banner').style.display = 'none';
    });
}
</script>
{% endif %}