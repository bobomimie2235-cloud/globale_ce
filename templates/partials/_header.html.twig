		{# ===== DROITE : RECHERCHE + CONNEXION ===== #}
		<div
			class="header-right">

			{# ===== INFO UTILISATEUR ===== #}
			{% if app.user %}
				<div class="info-user">
					<p>
						Bienvenue
						{{ app.user.nom }}
						{{ app.user.prenom }}, tu es bien connecté(e).
						<br>
						Tu es
						<strong>{{ app.user.roles[0]|replace({'ROLE_': ''}) }}</strong>
						et tu fais partie du groupe
						<strong>{{ app.user.utilisateurGroupe.nomGroupe }}</strong>.
					</p>
				</div>
			{% else %}
				<a href="{{ path('app_register') }}" class="btn-inscription">Inscription</a>
				<a href="{{ path('app_login') }}" class="btn-connexion">Connexion</a>
			{% endif %}
		</div>
	</div>

	{# ===== LIGNE SECONDAIRE : BARRE DE RECHERCHE ===== #}
	{% if is_granted('ROLE_USER') %}
		<div class="header-search">
			<form
				class="search-form" method="get" action="{{ path('app_recherche') }}">
				{# <select name="filtre">
				<option value="tout" {{ app.request.query.get('filtre') == 'tout' ? 'selected' : '' }}>Tout</option>
				<option value="articles" {{ app.request.query.get('filtre') == 'articles' ? 'selected' : '' }}>Articles</option>
				<option value="produits" {{ app.request.query.get('filtre') == 'produits' ? 'selected' : '' }}>Produits</option>
				<option value="coupons" {{ app.request.query.get('filtre') == 'coupons' ? 'selected' : '' }}>Coupons</option>
				</select> #}
				<div class="search-input-wrapper">
					<input type="text" name="q" placeholder="Rechercher un produit, une offre, un coupon..." value="{{ app.request.query.get('q') }}" autocomplete="off">
					<button type="submit" aria-label="Rechercher">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"/>
							<line x1="21" y1="21" x2="16.65" y2="16.65"/>
						</svg>
					</button>
				</div>
			</form>
		</div>
	{% endif %}
