<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>"> {% block stylesheets %}{% endblock %}

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>
	<body>
		<nav>
			<ul>
				{# Pages Public #}
				<li><a href="{{ path('app_accueil') }}">Accueil</a></li>
				{# Pages Administrateurs #}
				{% if is_granted('ROLE_ADMIN') %}
					<li><a href="{{ path('app_utilisateur_index') }}">Utilisateur</a></li>
					<li><a href="{{ path('app_utilisateur_groupe_index') }}">Utilisateur Groupe</a></li>
					<li><a href="{{ path('app_article_categorie_index') }}">Article Catégorie</a></li>
					<li><a href="{{ path('app_produit_categorie_index') }}">Produit Catégorie</a></li>
				{% endif %}
				{# Pages Utilisateurs #}
				{% if is_granted('ROLE_USER') %}
					<li><a href="{{ path('app_profil') }}">Profil Utilisateur</a></li>
					<li><a href="{{ path('app_logout') }}">Déconnexion</a></li>
					<li><a href="{{ path('app_article_index') }}">Offres Cartes</a></li>
					<li><a href="{{ path('app_produit_index') }}">Billetterie</a></li>
					<li><a href="{{ path('app_coupon_reduction_index') }}">Coupon Réduction</a></li>
					<li><a href="{{ path('app_commande_index') }}">Commande</a></li>
				{% else %}
					<li><a href="{{ path('app_register') }}">Inscription</a></li>
					<li><a href="{{ path('app_login') }}">Connexion</a></li>
				{% endif %}
			</ul>
		</nav>
		{% if app.user %}
			<p>
				Bienvenue
				{{ app.user.nom }}
				{{ app.user.prenom }}, tu es bien connecté(e).
				<br>
				Tu es
				<strong>{{ app.user.roles[0]|replace({'ROLE_': ''}) }}</strong>
				et 
												tu fais partie du groupe
				<strong>{{ app.user.utilisateurGroupe.nomGroupe }}</strong>.
			</p>
		{% endif %}
		{% block body %}{% endblock %}
	</body>
</html>
