{% extends 'base.html.twig' %}

{% block title %}Modifier Utilisateur{% endblock %}

{% block body %}
    <h1>Modifier Utilisateur</h1>

    <p>Roles : {{ form.vars.data.roles|join(', ') }}</p>

    {# ===== Changement de mot de passe — accessible à l'admin ET à l'utilisateur lui-même ===== #}
    {% if is_granted('ROLE_ADMIN') or app.user == utilisateur %}
        <h2>Modifier le mot de passe</h2>

        {{ form_start(passwordForm) }}
            {{ form_row(passwordForm.currentPassword) }}
            {{ form_row(passwordForm.newPassword.first) }}
            {{ form_row(passwordForm.newPassword.second) }}
            <button class="btn btn-warning">Changer le mot de passe</button>
        {{ form_end(passwordForm) }}
    {% endif %}

    {# ===== Modification du profil — accessible à l'admin ET à l'utilisateur lui-même ===== #}
    {% if is_granted('ROLE_ADMIN') or app.user == utilisateur %}
        {{ include('utilisateur/_form.html.twig', {'button_label': 'Modifier'}) }}
    {% else %}
        <p class="alert alert-warning">Vous n'avez pas les droits pour modifier cet utilisateur.</p>
    {% endif %}

    <a href="{{ path('app_utilisateur_index') }}">Retour à la liste</a>

    {# ===== Suppression — ROLE_ADMIN uniquement ===== #}
    {{ include('utilisateur/_delete_form.html.twig') }}
{% endblock %}
