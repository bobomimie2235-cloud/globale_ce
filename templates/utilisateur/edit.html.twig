{% extends 'base.html.twig' %}

{% block body %}
	<h1>Modifier mon profil</h1>

	{# ===== Modification du profil ===== #}
	<h2>Informations personnelles</h2>
	{{ form_start(form) }}
	{{ form_row(form.nom) }}
	{{ form_row(form.prenom) }}
	{{ form_row(form.email) }}
	<button class="btn btn-primary">Enregistrer</button>
	{{ form_end(form) }}

	{# ===== Changement de mot de passe ===== #}
	<h2>Modifier le mot de passe</h2>
	{{ form_start(passwordForm) }}
	{{ form_row(passwordForm.currentPassword) }}
	{{ form_row(passwordForm.newPassword.first) }}
	{{ form_row(passwordForm.newPassword.second) }}
	<button class="btn btn-warning">Changer le mot de passe</button>
	{{ form_end(passwordForm) }}

	{% if is_granted('ROLE_ADMIN') %}
		<a class="btn-return" href="{{ path('app_utilisateur_index') }}">Retour à la liste</a>
	{% else %}
		<a class="btn-return" href="{{ path('app_accueil') }}">Retour à l'accueil</a>
	{% endif %}

	{# Suppression — admin uniquement #}
	{% if is_granted('ROLE_ADMIN') %}
		{{ include('utilisateur/_delete_form.html.twig') }}
	{% endif %}
{% endblock %}
