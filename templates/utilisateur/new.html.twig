{% extends 'base.html.twig' %}

{% block title %}Nouvel Utilisateur{% endblock %}

{% block body %}
<section class="auth-page">
    <div class="auth-container auth-container--lg">
        <div class="auth-card">

            <a href="{{ path('app_utilisateur_index') }}" class="btn-return">← Retour à la liste</a>

            <h1 class="auth-titre">Nouvel Utilisateur</h1>
            <p class="auth-subtitle">Créer un nouveau compte utilisateur</p>

            {% if is_granted('ROLE_ADMIN') %}
                {{ include('utilisateur/_form.html.twig', {'button_label': 'Créer l\'utilisateur'}) }}
            {% else %}
                <p class="auth-warning">Vous n'avez pas les droits pour créer un utilisateur.</p>
            {% endif %}

        </div>
    </div>
</section>
{% endblock %}
