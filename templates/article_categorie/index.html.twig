{% extends 'base.html.twig' %}

{% block title %}ArticleCategorie index{% endblock %}

{% block body %}
    <h1>ArticleCategorie index</h1>

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_article_categorie_new') }}" class="btn btn-primary btn-sm">Créer une catégorie</a>
    {% endif %}

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Intitule</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for article_categorie in article_categories %}
            <tr>
                <td>{{ article_categorie.id }}</td>
                <td>{{ article_categorie.intitule }}</td>
                <td>
                    <a href="{{ path('app_article_categorie_show', {'id': article_categorie.id}) }}" class="btn btn-info btn-sm">Voir</a>

                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_article_categorie_edit', {'id': article_categorie.id}) }}" class="btn btn-warning btn-sm">Modifier</a>

                        <form method="post" action="{{ path('app_article_categorie_delete', {'id': article_categorie.id}) }}"
                            onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette catégorie ?');"
                            style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article_categorie.id) }}">
                            <button class="btn btn-danger btn-sm">Supprimer</button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">Aucune catégorie trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}