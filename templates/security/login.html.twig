{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<section class="auth-page">
    <div class="auth-container">

        <div class="auth-card">

            {# ===== TITRE ===== #}
            <h1 class="auth-titre">Connexion</h1>
            <p class="auth-subtitle">Accédez à votre espace personnel</p>

            {# ===== DÉJÀ CONNECTÉ ===== #}
            {% if app.user %}
                <div class="alert alert-info">
                    Connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>
                    — <a href="{{ logout_path() }}">Déconnexion</a>
                </div>
            {% endif %}

            {# ===== ERREUR ===== #}
            {% if error %}
                <div class="alert alert-danger">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {# ===== FORMULAIRE ===== #}
            <form method="post" class="auth-form">
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <div class="auth-field">
                    <label for="username">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="username"
                           autocomplete="email" required autofocus placeholder="votre@email.fr">
                </div>

                <div class="auth-field">
                    <label for="password">Mot de passe</label>
                    <input type="password" name="_password" id="password"
                           autocomplete="current-password" required placeholder="••••••••">
                </div>

                <div class="auth-remember">
                    <input type="checkbox" name="_remember_me" id="_remember_me">
                    <label for="_remember_me">Se souvenir de moi</label>
                </div>

                <button type="submit" class="btn-auth">Connexion</button>

                <div class="auth-links">
                    <a href="{{ path('app_forgot_password') }}">Mot de passe oublié ?</a>
                </div>

            </form>
        </div>
    </div>
</section>
{% endblock %}