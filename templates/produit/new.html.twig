{% extends 'base.html.twig' %}

{% block title %}Nouveau Produit{% endblock %}

{% block body %}
<section class="auth-page">
    <div class="auth-container auth-container--lg">
        <div class="auth-card">

            <a href="{{ path('app_produit_index') }}" class="btn-return">← Retour à la liste</a>

            <h1 class="auth-titre">Nouveau Produit</h1>
            <p class="auth-subtitle">Créer un nouveau produit billetterie</p>

            {% if is_granted('ROLE_ADMIN') %}
                {{ include('produit/_form.html.twig', {'button_label': 'Créer le produit'}) }}
            {% else %}
                <p class="auth-warning">Vous n'avez pas les droits pour créer un produit.</p>
            {% endif %}

        </div>
    </div>
</section>
{% endblock %}
