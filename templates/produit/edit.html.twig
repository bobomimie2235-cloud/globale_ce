{% extends 'base.html.twig' %}

{% block title %}Modifier Produit{% endblock %}

{% block body %}
    <h1>Modifier Produit</h1>

    {% if is_granted('ROLE_ADMIN') %}
        {{ include('produit/_form.html.twig', {'button_label': 'Modifier'}) }}
