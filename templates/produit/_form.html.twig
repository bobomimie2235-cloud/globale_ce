{% if is_granted('ROLE_ADMIN') %}
{{ form_start(form, {'attr': {'class': 'auth-form auth-form--grid'}}) }}

    <div class="auth-field">
        {{ form_label(form.reference, 'Référence') }}
        {{ form_widget(form.reference, {'attr': {'placeholder': 'Ex: PROD-001'}}) }}
        {{ form_errors(form.reference) }}
    </div>

    <div class="auth-field">
        {{ form_label(form.intitule, 'Intitulé') }}
        {{ form_widget(form.intitule, {'attr': {'placeholder': 'Nom du produit'}}) }}
        {{ form_errors(form.intitule) }}
    </div>

    <div class="auth-field auth-field--full">
        {{ form_label(form.description, 'Description') }}
        {{ form_widget(form.description, {'attr': {'placeholder': 'Description du produit'}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="auth-field">
        {{ form_label(form.prixPublic, 'Prix public (€)') }}
        {{ form_widget(form.prixPublic, {'attr': {'placeholder': '0.00'}}) }}
        {{ form_errors(form.prixPublic) }}
    </div>

    <div class="auth-field">
        {{ form_label(form.prixUnitaire, 'Prix membre (€)') }}
        {{ form_widget(form.prixUnitaire, {'attr': {'placeholder': '0.00'}}) }}
        {{ form_errors(form.prixUnitaire) }}
    </div>

    <div class="auth-field">
        {{ form_label(form.stock, 'Stock') }}
        {{ form_widget(form.stock, {'attr': {'placeholder': '0'}}) }}
        {{ form_errors(form.stock) }}
    </div>

    <div class="auth-field">
        {{ form_label(form.produitCategorie, 'Catégorie') }}
        {{ form_widget(form.produitCategorie) }}
        {{ form_errors(form.produitCategorie) }}
    </div>

    <div class="auth-field">
        {{ form_label(form.departement, 'Département') }}
        {{ form_widget(form.departement) }}
        {{ form_errors(form.departement) }}
    </div>

    <div class="auth-field auth-field--full">
        {{ form_label(form.logo, 'Logo du produit (PNG, JPG — max 2Mo)') }}
        {{ form_widget(form.logo) }}
        {{ form_errors(form.logo) }}
    </div>

    <div class="auth-field">
        {{ form_label(form.dateCreation, 'Date de création') }}
        {{ form_widget(form.dateCreation) }}
    </div>

    <div class="auth-field--full">
        <button type="submit" class="btn-auth">{{ button_label|default('Enregistrer') }}</button>
    </div>

{{ form_end(form) }}
{% else %}
    <p class="auth-warning">Vous n'avez pas les droits pour effectuer cette action.</p>
{% endif %}
