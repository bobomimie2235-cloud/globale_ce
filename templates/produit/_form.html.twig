{% if is_granted('ROLE_ADMIN') %}
    {{ form_start(form) }}
        {{ form_widget(form) }}
        <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
    {{ form_end(form) }}
{% else %}
    <p class="alert alert-warning">Vous n'avez pas les droits pour effectuer cette action.</p>
{% endif %}
