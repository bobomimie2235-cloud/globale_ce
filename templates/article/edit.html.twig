{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ article.titre }}{% endblock %}

{% block body %}
<section class="auth-page">
    <div class="auth-container auth-container--lg">
        <div class="auth-card">

            <a href="{{ path('app_article_index') }}" class="auth-back">← Retour à la liste</a>

            <h1 class="auth-titre">Modifier l'article</h1>
            <p class="auth-subtitle">{{ article.titre }}</p>

            {% if is_granted('ROLE_ADMIN') %}
                {{ include('article/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}

                <hr class="auth-divider">

                <div class="auth-danger">
                    <p class="auth-danger-label">⚠️ Supprimer cet article (action irréversible)</p>
                    {{ include('article/_delete_form.html.twig') }}
                </div>
            {% else %}
                <p class="auth-warning">Vous n'avez pas les droits pour modifier cet article.</p>
            {% endif %}

        </div>
    </div>
</section>
{% endblock %}
