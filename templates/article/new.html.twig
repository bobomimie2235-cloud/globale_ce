{% extends 'base.html.twig' %}

{% block title %}Nouvel Article{% endblock %}

{% block body %}
<section class="auth-page">
    <div class="auth-container auth-container--lg">
        <div class="auth-card">

            <a href="{{ path('app_article_index') }}" class="auth-back">← Retour à la liste</a>

            <h1 class="auth-titre">Nouvel Article</h1>
            <p class="auth-subtitle">Créer une nouvelle fiche commerçant</p>

            {% if is_granted('ROLE_ADMIN') %}
                {{ include('article/_form.html.twig', {'button_label': 'Créer l\'article'}) }}
            {% else %}
                <p class="auth-warning">Vous n'avez pas les droits pour créer un article.</p>
            {% endif %}

        </div>
    </div>
</section>
{% endblock %}
