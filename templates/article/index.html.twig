{% extends 'base.html.twig' %}

{% block title %}Article index{% endblock %}

{% block body %}
    <h1>Article index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Description</th>
                <th>InfosActivite</th>
                <th>SiteWeb</th>
                <th>ImgLogo</th>
                <th>ImgPhotosDevanture</th>
                <th>ImgPhotosInterieur</th>
                <th>OffreCommerciale</th>
                <th>Horaires</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for article in articles %}
            <tr>
                <td>{{ article.id }}</td>
                <td>{{ article.titre }}</td>
                <td>{{ article.description }}</td>
                <td>{{ article.infosActivite }}</td>
                <td>{{ article.siteWeb }}</td>
                <td>{{ article.imgLogo }}</td>
                <td>{{ article.imgPhotosDevanture }}</td>
                <td>{{ article.imgPhotosInterieur }}</td>
                <td>{{ article.offreCommerciale }}</td>
                <td>{{ article.horaires }}</td>
                <td>
                    <a href="{{ path('app_article_show', {'id': article.id}) }}">show</a>
                    <a href="{{ path('app_article_edit', {'id': article.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_article_new') }}">Create new</a>
{% endblock %}
